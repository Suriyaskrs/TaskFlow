{
  "info": {
    "name": "TaskFlow API - Complete (Day 4)",
    "description": "Full TaskFlow collection including admin endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "projectId", "value": "1" },
    { "key": "taskId", "value": "1" },
    { "key": "userId", "value": "1" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register (User)",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.data&&j.data.token){pm.collectionVariables.set('token',j.data.token);}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] }
          }
        },
        {
          "name": "Register (Admin)",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.data&&j.data.token){pm.collectionVariables.set('adminToken',j.data.token);}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@taskflow.com\",\n  \"password\": \"admin123\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/auth/register-admin?adminSecret=taskflow-admin-secret-2024",
              "host": ["{{baseUrl}}"],
              "path": ["auth","register-admin"],
              "query": [{ "key": "adminSecret", "value": "taskflow-admin-secret-2024" }]
            },
            "description": "Admin token is auto-saved separately from user token."
          }
        },
        {
          "name": "Login (User)",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.data&&j.data.token){pm.collectionVariables.set('token',j.data.token);}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"secret123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.data&&j.data.token){pm.collectionVariables.set('adminToken',j.data.token);}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@taskflow.com\",\n  \"password\": \"admin123\"\n}" },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] }
          }
        }
      ]
    },
    {
      "name": "2. Admin",
      "item": [
        {
          "name": "Get System Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/stats", "host": ["{{baseUrl}}"], "path": ["admin","stats"] },
            "description": "Returns system-wide totals: users, projects, tasks, completion rate."
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/users?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin","users"],
              "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }]
            }
          }
        },
        {
          "name": "Delete User By ID",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["admin","users","{{userId}}"] },
            "description": "⚠️ Deletes user and ALL their projects and tasks. Change userId variable."
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/admin/projects?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin","projects"],
              "query": [{ "key": "page", "value": "0" }, { "key": "size", "value": "20" }]
            }
          }
        },
        {
          "name": "Delete Project By ID",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["admin","projects","{{projectId}}"] },
            "description": "⚠️ Deletes project and ALL its tasks."
          }
        },
        {
          "name": "Delete Task By ID",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/admin/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["admin","tasks","{{taskId}}"] }
          }
        }
      ]
    },
    {
      "name": "3. Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/users/me", "host": ["{{baseUrl}}"], "path": ["users","me"] }
          }
        },
        {
          "name": "Delete My Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users/me?confirmPassword=secret123",
              "host": ["{{baseUrl}}"],
              "path": ["users","me"],
              "query": [{ "key": "confirmPassword", "value": "secret123" }]
            }
          }
        }
      ]
    },
    {
      "name": "4. Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.data&&j.data.id){pm.collectionVariables.set('projectId',j.data.id);}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"My First Project\",\n  \"description\": \"A test project\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          }
        },
        {
          "name": "Get All Projects",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects", "host": ["{{baseUrl}}"], "path": ["projects"] }
          }
        },
        {
          "name": "Get Project By ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}"] }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Name\",\n  \"description\": \"Updated description\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}"] }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}"] }
          }
        }
      ]
    },
    {
      "name": "5. Analytics",
      "item": [
        {
          "name": "Get Project Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/analytics", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","analytics"] }
          }
        }
      ]
    },
    {
      "name": "6. Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [{ "listen": "test", "script": { "exec": ["var j=pm.response.json(); if(j.data&&j.data.id){pm.collectionVariables.set('taskId',j.data.id);}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Design the login page\",\n  \"description\": \"Create wireframes\",\n  \"priority\": \"HIGH\",\n  \"status\": \"TODO\",\n  \"deadline\": \"2026-12-31\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks"] }
          }
        },
        {
          "name": "Get Tasks (Paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks?page=0&size=10&sort=priority",
              "host": ["{{baseUrl}}"],
              "path": ["projects","{{projectId}}","tasks"],
              "query": [{ "key": "page", "value": "0" },{ "key": "size", "value": "10" },{ "key": "sort", "value": "priority" }]
            }
          }
        },
        {
          "name": "Get All Tasks (No Pagination)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/all", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks","all"] }
          }
        },
        {
          "name": "Search Tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/search?keyword=login&page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["projects","{{projectId}}","tasks","search"],
              "query": [{ "key": "keyword", "value": "login" },{ "key": "page", "value": "0" },{ "key": "size", "value": "10" }]
            }
          }
        },
        {
          "name": "Get Tasks By Priority",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/priority/HIGH", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks","priority","HIGH"] }
          }
        },
        {
          "name": "Get Overdue Tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/overdue", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks","overdue"] }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" },{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" },
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks","{{taskId}}"] }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/{{taskId}}", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks","{{taskId}}"] }
          }
        },
        {
          "name": "Bulk Delete by Status",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/status/DONE", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks","status","DONE"] }
          }
        },
        {
          "name": "Delete ALL Tasks",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{baseUrl}}/projects/{{projectId}}/tasks/all", "host": ["{{baseUrl}}"], "path": ["projects","{{projectId}}","tasks","all"] }
          }
        }
      ]
    }
  ]
}